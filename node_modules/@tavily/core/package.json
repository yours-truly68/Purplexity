{
  "name": "@tavily/core",
  "version": "0.7.6",
  "description": "Official JavaScript library for Tavily.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "homepage": "https://tavily.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/tavily-ai/tavily-js.git"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "search",
    "crawl",
    "extract",
    "agent",
    "ai",
    "tavily"
  ],
  "author": "Tavily",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsup": "^8.3.6",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "https-proxy-agent": "^7.0.6",
    "js-tiktoken": "^1.0.14"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
